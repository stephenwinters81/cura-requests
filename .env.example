# Database
DATABASE_URL="postgresql://user:password@localhost:5432/requests?schema=public"

# Auth
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="https://requests.curaspecialists.com.au"
MFA_ISSUER="CURA Requests"

# SMTP (Google Workspace)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="clinic@curaspecialists.com.au"
SMTP_PASSWORD="your-google-app-password"
SMTP_FROM="clinic@curaspecialists.com.au"

# Notifyre Fax
NOTIFYRE_API_KEY="your-notifyre-api-key"
NOTIFYRE_WEBHOOK_SECRET="your-notifyre-webhook-secret"
NOTIFYRE_SENDER_ID="your-notifyre-sender-id"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# PDF Storage
PDF_STORAGE_PATH="./data/pdfs"
PDF_ENCRYPTION_KEY="generate-a-32-byte-hex-key"

# Field-level Encryption (pgcrypto)
FIELD_ENCRYPTION_KEY="generate-a-secure-encryption-key"

# Security
ALLOWED_IPS=""
RATE_LIMIT_LOGIN="5"
RATE_LIMIT_SUBMIT="60"
SESSION_TIMEOUT_MINUTES="15"
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MINUTES="30"

# Health Check
HEALTH_CHECK_TOKEN="generate-a-random-token"

# Data Retention
ACTIVE_RETENTION_DAYS="90"
ARCHIVE_RETENTION_YEARS="7"

# App
NEXT_PUBLIC_APP_URL="https://requests.curaspecialists.com.au"
NODE_ENV="development"
